# ── 데이터베이스 설정 ──────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=steel_wip_db

# 프론트 배포 도메인(쉼표로 여러 개 가능)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Railway 등 운영 환경에서 시드 자동 적재 여부
AUTO_SEED=true

# ── Jira 연동 (GitHub Actions Secrets에도 동일하게 등록) ──
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_USER_EMAIL=your@email.com
# JIRA_DONE_TRANSITION_ID=31

# ── JWT 설정 ──────────────────────────────────────
JWT_SECRET_KEY=여기에-매우-긴-랜덤-문자열을-입력하세요